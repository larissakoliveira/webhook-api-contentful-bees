# Used locally (npm run dev) and on Vercel — same variable names in Vercel → Settings → Environment Variables

EMAIL_USER=
EMAIL_PASS=
CONTENTFUL_SPACE_ID=
CONTENTFUL_ACCESS_TOKEN_MANAGEMENT_API=

# Contentful environment: master | staging (must match bee-app and webhook Contentful settings)
# CONTENTFUL_ENVIRONMENT_ID=master

# Same API identifier as bee-app (e.g. eMailRegistration). Prefer this name on the webhook.
CONTENTFUL_EMAIL_REGISTRATION_CONTENT_TYPE_ID=
# Optional: same value under the bee-app name if you reuse env keys on Vercel — code accepts either.
# VITE_CONTENTFUL_EMAIL_REGISTRATION_CONTENT_TYPE_ID=

# Only if the Reference field API id is not "relatedProduct"
# CONTENTFUL_EMAIL_RELATED_PRODUCT_FIELD_ID=relatedProduct

# Optional: field API ids / locale for POST /api/registerEmail (defaults match bee-app)
# CONTENTFUL_EMAIL_REGISTRATION_EMAIL_FIELD_ID=email
# CONTENTFUL_EMAIL_REGISTRATION_LANGUAGE_FIELD_ID=language
# Locale key used when writing registration fields (default en-US; use nl if your space has no en-US)
# CONTENTFUL_EMAIL_REGISTRATION_LOCALE=en-US

# Browser CORS for bee-app → register endpoint (* or comma-separated origins, e.g. https://bij-zonderezaken.nl)
# EMAIL_REGISTER_CORS_ORIGIN=*

# Optional shared secret: bee-app sends header X-Bee-Register-Secret (same value as VITE_EMAIL_REGISTER_SHARED_SECRET)
# EMAIL_REGISTER_SHARED_SECRET=
